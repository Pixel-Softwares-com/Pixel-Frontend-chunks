{
  "name": "pixel-request-chunks",
  "version": "0.5.0",
  "description": "Transport-level chunking for HTTP requests with form snapshots and recovery.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pixel-Softwares-com/Pixel-Frontend-chunks.git"
  },
  "bugs": {
    "url": "https://github.com/Pixel-Softwares-com/Pixel-Frontend-chunks/issues"
  },
  "homepage": "https://github.com/Pixel-Softwares-com/Pixel-Frontend-chunks#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
